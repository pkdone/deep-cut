{
  "name": "deep-cut",
  "version": "0.1.0",
  "description": "DeepCut desktop music player — Spotify + local MP3",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --linux deb",
    "build:app": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "validate": "npm run lint && npm run test && npm run build:app",
    "db:init": "tsx scripts/db-init.ts",
    "db:teardown": "tsx scripts/db-teardown.ts"
  },
  "engines": {
    "node": ">=22.21.1"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "dotenv": "^16.6.1",
    "mongodb": "^6.12.0",
    "music-metadata": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^7.3.2"
  },
  "build": {
    "appId": "com.deepcut.app",
    "productName": "DeepCut",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "linux": {
      "maintainer": "DeepCut <maintainer@example.com>",
      "target": [
        "deb"
      ],
      "category": "Audio"
    }
  }
}
