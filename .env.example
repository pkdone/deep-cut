# Copy to .env.local (gitignored). Single URI for MongoDB Atlas.
MONGODB_URI="mongodb+srv://user:pass@cluster.example.mongodb.net/deepcut?retryWrites=true&w=majority"

# Optional — only for local `npm run test:integration` (live OpenAI / Anthropic calls).
# The desktop app stores LLM API keys in Settings (MongoDB), not in these variables.
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
